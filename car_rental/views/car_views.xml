<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Car Form View -->
    <record id="view_car_form" model="ir.ui.view">
        <field name="name">car.rental.car.form</field>
        <field name="model">car.rental.car</field>
        <field name="arch" type="xml">
            <form string="Car">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="brand"/>
                        <field name="model"/>
                        <field name="year"/>
                        <field name="price_per_day"/>
                        <field name="available"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Car Tree View -->
    <record id="view_car_tree" model="ir.ui.view">
        <field name="name">car.rental.car.tree</field>
        <field name="model">car.rental.car</field>
        <field name="arch" type="xml">
            <tree string="Cars">
                <field name="name"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="year"/>
                <field name="price_per_day"/>
                <field name="available"/>
            </tree>
        </field>
    </record>

    <!-- Car Action -->
    <record id="action_car" model="ir.actions.act_window">
        <field name="name">Cars</field>
        <field name="res_model">car.rental.car</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first car!
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_car_rental_root" name="Car Rental" sequence="10"/>
    <menuitem id="menu_cars" name="Cars" parent="menu_car_rental_root" action="action_car" sequence="10"/>
</odoo>
